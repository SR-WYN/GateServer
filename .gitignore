# ==========================================
# 1. 编译输出与构建目录 (CMake)
# ==========================================
build/
bin/
lib/
dist/
# 即使你在根目录误操作生成的中间文件也要忽略
CMakeFiles/
CMakeCache.txt
CMakeScripts/
cmake_install.cmake
install/
Makefile
CTestTestfile.cmake
compile_commands.json

# ==========================================
# 2. Qt Creator & IDE 配置文件
# ==========================================
# 核心：忽略 Qt Creator 自动生成的本地用户设置
*.txt.user
*.txt.user.*
.qtc_clangd/
.qt_design_studio/
*.orig
*.rej

# VS Code 缓存
.vscode/
.history/

# ==========================================
# 3. 语言服务器缓存 (Clangd)
# ==========================================
.clangd/
.cache/

# ==========================================
# 4. 自动生成的代码 (gRPC / Proto / Qt)
# ==========================================
# 建议通过 .proto 生成，不提交生成的 .pb.cc/.h
*.pb.cc
*.pb.h
*.grpc.pb.cc
*.grpc.pb.h

# Qt 自动生成的代码
moc_*.cpp
ui_*.h
qrc_*.cpp
*.moc

# ==========================================
# 5. 库文件与二进制 (Boost / JsonCpp 等)
# ==========================================
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.obj
*.o
*.pch

# ==========================================
# 6. 系统与临时文件
# ==========================================
.DS_Store
Thumbs.db
desktop.ini
*.log
*.tmp
*.bak
*~
node_modules
